<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2F8">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔐 Mật khẩu mở cửa"
            android:textColor="#1D2A44"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDoorPasswordCurrent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#DDE8FF"
            android:padding="12dp"
            android:text="Đang tải trạng thái mật khẩu..."
            android:textColor="#173A79"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etDoorPasswordOld"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="#FFFFFF"
            android:hint="Mật khẩu cũ (để trống nếu chưa khởi tạo)"
            android:inputType="textPassword"
            android:padding="12dp" />

        <EditText
            android:id="@+id/etDoorPasswordNew"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#FFFFFF"
            android:hint="Mật khẩu mới"
            android:inputType="textPassword"
            android:padding="12dp" />

        <Button
            android:id="@+id/btnDoorPasswordSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Lưu mật khẩu" />

        <Button
            android:id="@+id/btnDoorPasswordBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Quay lại" />

        <TextView
            android:id="@+id/tvDoorPasswordStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#DDE8FF"
            android:padding="12dp"
            android:text="Nhập thông tin để tạo/đổi mật khẩu cửa"
            android:textColor="#173A79"
            android:textSize="14sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
